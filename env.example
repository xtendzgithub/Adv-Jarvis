# ═══════════════════════════════════════════════════════════════
#  J.A.R.V.I.S. — Environment Variables Template
#  Copy this file to .env and fill in your API keys
#  NEVER commit .env to GitHub!
# ═══════════════════════════════════════════════════════════════

# ── OpenAI ──────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...your-key-here...
OPENAI_MODEL=gpt-4o

# ── GitHub ──────────────────────────────────────────────────────
# Create a Personal Access Token at: https://github.com/settings/tokens
# Required scopes: repo, read:user, notifications
GITHUB_TOKEN=ghp_...your-token-here...
GITHUB_USERNAME=your-github-username

# ── Weather (OpenWeatherMap) ─────────────────────────────────────
# Free key at: https://openweathermap.org/api
OPENWEATHER_API_KEY=your-openweather-key
DEFAULT_CITY=Mumbai

# ── Wolfram Alpha (optional) ─────────────────────────────────────
WOLFRAM_APP_ID=your-wolfram-app-id

# ── Email (Gmail with App Password) ─────────────────────────────
EMAIL_ADDRESS=your@gmail.com
EMAIL_PASSWORD=your-app-password
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# ── Database ─────────────────────────────────────────────────────
DB_PATH=data/jarvis_memory.db

# ── TTS Settings ─────────────────────────────────────────────────
TTS_RATE=175
TTS_VOLUME=1.0
TTS_VOICE=female
